# Manus-preset secrets keystore
# Read by the agent before falling back. Empty = "ask the user".
# Format: KEY=value (one per line, no spaces around =).

# web-search-tavily
TAVILY_API_KEY=

# gmail (managed OAuth via Maton)
MATON_API_KEY=

# google-calendar (path to credentials.json from Google Cloud Console)
GOOGLE_OAUTH_CREDS_PATH=

# web-search-searxng: requires Docker — see TOOLS.md
